        <omgdc:Bounds x="930" y="128" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_0yieljv_di" bpmnElement="decision" isMarkerVisible="true" bioc:stroke="#5b176d" bioc:fill="#e1bee7" color:background-color="#e1bee7" color:border-color="#5b176d">
        <omgdc:Bounds x="1095" y="143" width="50" height="50" />
